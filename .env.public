# KaraLingo Environment Configuration
# Copy this file to .env or .env.local and fill in your values.
# .env.local is gitignored and safe for secrets.

# ── ACRCloud (Song Recognition) ──────────────────────────────────
VITE_ACRCLOUD_HOST=
VITE_ACRCLOUD_KEY=
VITE_ACRCLOUD_SECRET=

# ── Genius API (Lyrics fallback) ─────────────────────────────────
VITE_GENIUS_KEY=

# ── LibreTranslate (Translation) ─────────────────────────────────
VITE_LIBRETRANSLATE_URL=https://libretranslate.com
